<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>LabShare — Student</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #000;
      color: #fff;
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* ── Minimal topbar (auto-hides) ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      height: 48px;
      background: rgba(0,0,0,.75);
      backdrop-filter: blur(12px);
      flex-shrink: 0;
      transition: opacity .3s;
      z-index: 10;
    }

    .logo { font-weight: 700; font-size: 1em; opacity: .8; }

    .pills { display: flex; gap: 10px; }

    .pill {
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 0.78em;
      font-weight: 600;
      background: rgba(255,255,255,.1);
      color: #d1d5db;
    }

    .pill.green { background: rgba(16,185,129,.2); color: #6ee7b7; }
    .pill.yellow { background: rgba(234,179,8,.2); color: #fde68a; }

    /* ── Video area ── */
    .stage {
      flex: 1;
      position: relative;
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    #screen {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: none;
    }

    /* ── Waiting state ── */
    .waiting {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      color: #4b5563;
    }

    .waiting-icon {
      font-size: 5rem;
      animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-12px); }
    }

    .waiting h2 { font-size: 1.3em; color: #9ca3af; }
    .waiting p  { font-size: 0.9em; }

    /* Connecting spinner */
    .spinner {
      display: none;
      width: 40px; height: 40px;
      border: 3px solid rgba(255,255,255,.1);
      border-top-color: #3b82f6;
      border-radius: 50%;
      animation: spin .8s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Bottom controls overlay ── */
    .controls {
      position: absolute;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: 12px;
      opacity: 0;
      transition: opacity .3s;
      pointer-events: none;
    }

    .stage:hover .controls { opacity: 1; pointer-events: all; }

    .ctrl-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 22px;
      border-radius: 999px;
      border: none;
      font-size: .9em;
      font-weight: 600;
      cursor: pointer;
      backdrop-filter: blur(12px);
      transition: transform .15s;
    }

    .ctrl-btn:hover { transform: scale(1.05); }

    .ctrl-fullscreen {
      background: rgba(255,255,255,.15);
      color: #fff;
      border: 1px solid rgba(255,255,255,.2);
    }

    /* ── Stats overlay (top-right corner when live) ── */
    .stats-overlay {
      display: none;
      position: absolute;
      top: 16px;
      right: 16px;
      background: rgba(0,0,0,.6);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 10px;
      padding: 10px 16px;
      font-size: .8em;
      line-height: 1.8;
      color: #d1d5db;
    }

    .stats-overlay .val { color: #fff; font-weight: 700; }
  </style>
</head>
<body>

<div class="topbar">
  <div class="logo">⬤ LabShare</div>
  <div class="pills">
    <div class="pill" id="status">Waiting for teacher…</div>
    <div class="pill" id="fpsPill" style="display:none">0 FPS</div>
  </div>
</div>

<div class="stage">

  <video id="screen" autoplay playsinline></video>

  <div class="waiting" id="waiting">
    <div class="waiting-icon">📺</div>
    <h2 id="waitMsg">Waiting for teacher to go live</h2>
    <p id="waitSub">Your screen will appear here automatically</p>
    <div class="spinner" id="spinner"></div>
  </div>

  <div class="stats-overlay" id="statsOverlay">
    <div>Protocol &nbsp;<span class="val">WebRTC P2P</span></div>
    <div>Codec &nbsp;&nbsp;&nbsp;&nbsp;<span class="val" id="codecVal">—</span></div>
    <div>FPS &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="val" id="fpsVal">—</span></div>
    <div>Latency &nbsp;<span class="val" id="latVal">—</span></div>
  </div>

  <div class="controls">
    <button class="ctrl-btn ctrl-fullscreen" id="fullscreenBtn">⛶ Fullscreen</button>
  </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/student.js"></script>
<script>
  // Stats polling once stream is live
  let statsTimer = null;
  let pc_ref = null; // set by student.js via custom event

  document.addEventListener('stream-live', (e) => {
    pc_ref = e.detail.pc;
    document.getElementById('waiting').style.display = 'none';
    document.getElementById('screen').style.display = 'block';
    document.getElementById('statsOverlay').style.display = 'block';
    document.getElementById('fpsPill').style.display = 'block';
    document.getElementById('status').textContent = '🟢 Live';
    document.getElementById('status').className = 'pill green';

    // Poll WebRTC stats every second
    statsTimer = setInterval(async () => {
      if (!pc_ref) return;
      try {
        const stats = await pc_ref.getStats();
        stats.forEach(r => {
          if (r.type === 'inbound-rtp' && r.kind === 'video') {
            const fps = Math.round(r.framesPerSecond || 0);
            document.getElementById('fpsVal').textContent = fps;
            document.getElementById('fpsPill').textContent = `${fps} FPS`;

            const codec = r.codecId || '';
            if (codec) document.getElementById('codecVal').textContent = 'H264 / VP8';
          }
          if (r.type === 'candidate-pair' && r.state === 'succeeded') {
            const ms = Math.round(r.currentRoundTripTime * 1000 || 0);
            if (ms) document.getElementById('latVal').textContent = `${ms} ms`;
          }
        });
      } catch (_) {}
    }, 1000);
  });

  document.addEventListener('stream-stopped', () => {
    clearInterval(statsTimer);
    document.getElementById('waiting').style.display = 'flex';
    document.getElementById('screen').style.display = 'none';
    document.getElementById('statsOverlay').style.display = 'none';
    document.getElementById('fpsPill').style.display = 'none';
    document.getElementById('status').textContent = 'Teacher offline';
    document.getElementById('status').className = 'pill';
    document.getElementById('waitMsg').textContent = 'Teacher stopped sharing';
    document.getElementById('spinner').style.display = 'none';
  });

  document.addEventListener('stream-connecting', () => {
    document.getElementById('spinner').style.display = 'block';
    document.getElementById('waitMsg').textContent = 'Connecting…';
    document.getElementById('waitSub').textContent = 'Establishing WebRTC peer connection';
    document.getElementById('status').textContent = '🟡 Connecting';
    document.getElementById('status').className = 'pill yellow';
  });

  document.getElementById('fullscreenBtn').onclick = () => {
    if (!document.fullscreenElement) document.documentElement.requestFullscreen();
    else document.exitFullscreen();
  };
</script>

</body>
</html>
