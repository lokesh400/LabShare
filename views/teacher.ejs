<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>LabShare — Teacher</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #111827;
      color: #f9fafb;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Top bar ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      height: 64px;
      background: #1f2937;
      border-bottom: 1px solid #374151;
      flex-shrink: 0;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1.2em;
      font-weight: 700;
    }

    .logo-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: #10b981;
    }

    .logo-dot.offline { background: #6b7280; }

    .pills {
      display: flex;
      gap: 10px;
    }

    .pill {
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 0.82em;
      font-weight: 600;
      background: #374151;
      color: #d1d5db;
    }

    .pill.green  { background: #064e3b; color: #6ee7b7; }
    .pill.blue   { background: #1e3a5f; color: #93c5fd; }

    /* ── Main area ── */
    .main {
      flex: 1;
      display: flex;
      overflow: hidden;
    }

    .preview-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
      gap: 20px;
    }

    #placeholder {
      text-align: center;
      color: #4b5563;
    }

    #placeholder .icon { font-size: 5rem; margin-bottom: 16px; }
    #placeholder h2 { font-size: 1.4em; margin-bottom: 8px; color: #9ca3af; }
    #placeholder p  { font-size: 0.95em; }

    #preview {
      display: none;
      width: 100%;
      max-height: calc(100vh - 200px);
      border-radius: 12px;
      box-shadow: 0 0 0 2px #10b981, 0 20px 60px rgba(0,0,0,0.6);
      object-fit: contain;
      background: #000;
    }

    .controls {
      display: flex;
      gap: 14px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 32px;
      border: none;
      border-radius: 999px;
      font-size: 1em;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
    }

    .btn:hover   { opacity: .88; transform: translateY(-1px); }
    .btn:active  { transform: translateY(0); }

    .btn-primary  { background: #2563eb; color: #fff; }
    .btn-stop     { background: #dc2626; color: #fff; display: none; }

    /* ── Side panel ── */
    .panel {
      width: 260px;
      background: #1f2937;
      border-left: 1px solid #374151;
      padding: 24px 20px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      overflow-y: auto;
    }

    .panel h3 {
      font-size: 0.78em;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: #6b7280;
      margin-bottom: 4px;
    }

    .stat-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 14px;
      background: #111827;
      border-radius: 8px;
    }

    .stat-row span:first-child { font-size: 0.88em; color: #9ca3af; }
    .stat-row span:last-child  { font-size: 0.95em; font-weight: 600; }

    .feat-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .feat-list li {
      font-size: 0.85em;
      color: #d1d5db;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .feat-list li::before {
      content: '';
      width: 6px; height: 6px;
      background: #10b981;
      border-radius: 50%;
      flex-shrink: 0;
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="logo">
    <div class="logo-dot offline" id="liveDot"></div>
    LabShare Teacher
  </div>
  <div class="pills">
    <div class="pill" id="status">Idle</div>
    <div class="pill blue" id="connectedCount">0 students</div>
  </div>
</div>

<div class="main">

  <div class="preview-wrap">
    <div id="placeholder">
      <div class="icon">🖥️</div>
      <h2>Nothing is being shared</h2>
      <p>Click <strong>Start Sharing</strong> below to broadcast your screen</p>
    </div>

    <video id="preview" autoplay muted playsinline></video>

    <div class="controls">
      <button class="btn btn-primary" id="startBtn">▶&nbsp; Start Sharing</button>
      <button class="btn btn-stop"    id="stopBtn" >⏹&nbsp; Stop Sharing</button>
    </div>
  </div>

  <div class="panel">
    <div>
      <h3>Live Stats</h3>
      <div style="display:flex;flex-direction:column;gap:8px;margin-top:8px">
        <div class="stat-row">
          <span>Protocol</span><span id="proto">WebRTC</span>
        </div>
        <div class="stat-row">
          <span>Video</span><span id="resolution">—</span>
        </div>
        <div class="stat-row">
          <span>Students</span><span id="studentStat">0</span>
        </div>
      </div>
    </div>

    <div>
      <h3>Technology</h3>
      <ul class="feat-list">
        <li>Peer-to-peer (no re-encoding)</li>
        <li>Hardware H.264 / VP8 codec</li>
        <li>Adaptive bitrate</li>
        <li>STUN NAT traversal</li>
        <li>Sub-50 ms latency</li>
        <li>60 FPS capable</li>
      </ul>
    </div>

    <div>
      <h3>How to use</h3>
      <ul class="feat-list">
        <li>Click Start Sharing</li>
        <li>Pick screen or window</li>
        <li>Students open /student</li>
        <li>Stream starts instantly</li>
      </ul>
    </div>
  </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/teacher.js"></script>
<script>
  // Wire up UI updates from teacher.js events (called by teacher.js via custom events)
  document.addEventListener('sharing-started', (e) => {
    const { width, height } = e.detail || {};
    document.getElementById('resolution').textContent = width ? `${width}×${height}` : '—';
    document.getElementById('status').textContent = '🔴 Live';
    document.getElementById('status').className = 'pill green';
    document.getElementById('liveDot').className = 'logo-dot';
  });
  document.addEventListener('sharing-stopped', () => {
    document.getElementById('resolution').textContent = '—';
    document.getElementById('status').textContent = 'Idle';
    document.getElementById('status').className = 'pill';
    document.getElementById('liveDot').className = 'logo-dot offline';
  });
  document.addEventListener('student-count-updated', (e) => {
    const n = e.detail.count;
    document.getElementById('connectedCount').textContent = `${n} student${n !== 1 ? 's' : ''}`;
    document.getElementById('studentStat').textContent = n;
  });
</script>

</body>
</html>
